{
  "name": "WeeklyChallengeSettings",
  "type": "object",
  "properties": {
    "is_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether the weekly challenge is enabled for users"
    },
    "week_label": {
      "type": "string",
      "description": "Label for the current week, e.g. 'March Week 2'"
    },
    "description": {
      "type": "string",
      "description": "Optional intro text shown to students"
    },
    "course_id": {
      "type": "string",
      "description": "The course this quiz unlocks access to the NEXT course for. Students need \u226590% to advance."
    }
  },
  "required": []
}